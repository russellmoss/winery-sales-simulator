{
  "name": "winery-sales-simulator",
  "version": "1.0.0",
  "description": "A simulator for winery sales training",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "init-firestore": "node scripts/init-firestore.js"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.1",
    "node-fetch": "^2.7.0",
    "recharts": "^2.15.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
